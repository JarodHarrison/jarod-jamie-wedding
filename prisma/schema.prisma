generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum GuestTier {
  PENTHOUSE
  ON_SITE
  OFF_SITE
}

enum ShuttleSessionStatus {
  ACTIVE
  ENDED
}

enum ShuttleStopStatusType {
  PENDING
  EN_ROUTE
  ARRIVED
  DEPARTED
  COMPLETED
}

enum PartyRole {
  BEST_BITCH
}

model Guest {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  passwordPlaintext String?
  tier         GuestTier  @default(OFF_SITE)
  rsvpStatus   RsvpStatus @default(PENDING)
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz

  phone            String?
  plusOneName      String?
  plusOneGuestId   String?
  plusOneGuest     Guest?  @relation("GuestPlusOne", fields: [plusOneGuestId], references: [id], onDelete: SetNull)
  plusOneOf        Guest[] @relation("GuestPlusOne")
  companionPhotoMime String?
  companionPhotoData Bytes?
  partyRole        PartyRole?
  dietaryNotes     String?
  songRequest      String?
  rsvpSubmittedAt  DateTime? @db.Timestamptz

  accommodationType        String?
  accommodationName        String?
  accommodationAddress     String?
  checkInDate              String?
  checkOutDate             String?
  needsShuttle             Boolean?
  accommodationNotes       String?
  accommodationSubmittedAt DateTime? @db.Timestamptz

  wantsSharedTransfer Boolean?
  arrivalAirport      String?
  arrivalDate         String?
  arrivalTime         String?
  departureAirport    String?
  departureDate       String?
  departureTime       String?
  flightNumber        String?
  passengerCount      Int?
  transferNotes       String?
  transferSubmittedAt DateTime? @db.Timestamptz

  glowUpInterest        String?
  onSiteServiceInterest String?
  interestsSubmittedAt  DateTime? @db.Timestamptz

  profilePhotoMime      String?
  profilePhotoData      Bytes?
  guestOfHost           String?
  guestRelationship     String?
  guestRelationshipNote String?
  profileUpdatedAt      DateTime? @db.Timestamptz

  sayiPartyName         String?
  sayiLink              String?
  sayiPlusOneAllowed    Boolean?
  mailingAddress        String?
  sayiImportedAt        DateTime? @db.Timestamptz
  sayiCustomData        Json?

  goldCoastTrip GoldCoastTrip?
  passwordResetTokens GuestPasswordResetToken[]
  passkeyCredentials PasskeyCredential[]
  notifications InAppNotification[]
  bingoProgress PhotoboothBingoProgress?
  guestStories GuestStory[]
  sharedPhotos GuestSharedPhoto[]
}

model InAppNotification {
  id        String    @id @default(cuid())
  guestId   String
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  title     String
  body      String
  imageUrl  String?
  readAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@index([guestId, createdAt(sort: Desc)])
  @@index([guestId, readAt])
}

model PhotoboothBingoProgress {
  id           String    @id @default(cuid())
  guestId      String    @unique
  guest        Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  checkedItems String[]  @default([])
  completedAt  DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
}

enum GuestStoryStatus {
  APPROVED
  HIDDEN
  PENDING
}

enum GuestPhotoStatus {
  PENDING
  APPROVED
  HIDDEN
}

model GuestStory {
  id          String           @id @default(cuid())
  guestId     String
  guest       Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  content     String
  mood        String
  isAnonymous Boolean          @default(false)
  status      GuestStoryStatus @default(APPROVED)
  reportCount Int              @default(0)
  createdAt   DateTime         @default(now()) @db.Timestamptz

  @@index([createdAt(sort: Desc)])
  @@index([guestId])
  @@index([status])
}

model GuestPasswordResetToken {
  id        String    @id @default(cuid())
  guestId   String
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@index([guestId])
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  passkeyCredentials PasskeyCredential[]
}

model PasskeyCredential {
  id           String    @id @default(cuid())
  guestId      String?
  guest        Guest?    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  adminId      String?
  admin        Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    String
  counter      BigInt    @default(0)
  deviceType   String?
  backedUp     Boolean   @default(false)
  transports   String?
  nickname     String?
  createdAt    DateTime  @default(now()) @db.Timestamptz
  lastUsedAt   DateTime? @db.Timestamptz

  @@index([guestId])
  @@index([adminId])
}

model GoldCoastTrip {
  id         String   @id @default(cuid())
  guestId    String   @unique
  guest      Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  amountPaid Decimal  @default(0) @db.Decimal(10, 2)
  balanceDue Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
}

model Vendor {
  id           String   @id @default(cuid())
  name         String
  category     String
  contactName  String?
  phone        String?
  email        String?
  website      String?
  notes        String?
  sortOrder    Int      @default(0)
  documentName String?
  documentMime String?
  documentData Bytes?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
}

enum KioskSessionStatus {
  PENDING
  ACTIVE
  ENDED
}

model KioskSession {
  id                    String             @id @default(cuid())
  displayCode           String             @unique
  feedToken             String             @unique
  status                KioskSessionStatus @default(PENDING)
  activatedAt           DateTime?          @db.Timestamptz
  activatedByAdminEmail String?
  expiresAt             DateTime?          @db.Timestamptz
  createdAt             DateTime           @default(now()) @db.Timestamptz
  updatedAt             DateTime           @updatedAt @db.Timestamptz

  @@index([status, createdAt(sort: Desc)])
}

model GuestSharedPhoto {
  id              String           @id @default(cuid())
  guestId         String
  guest           Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  mime            String
  photoData       Bytes
  caption         String?
  status          GuestPhotoStatus @default(PENDING)
  visionSafeSearch Json?
  driveFileId     String?
  driveUploadedAt DateTime?        @db.Timestamptz
  createdAt       DateTime         @default(now()) @db.Timestamptz

  @@index([guestId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model ShuttleRoute {
  id        String           @id @default(cuid())
  name      String
  active    Boolean          @default(true)
  createdAt DateTime         @default(now()) @db.Timestamptz
  stops     ShuttleStop[]
  sessions  ShuttleSession[]
}

model ShuttleStop {
  id                   String              @id @default(cuid())
  routeId              String
  route                ShuttleRoute        @relation(fields: [routeId], references: [id], onDelete: Cascade)
  slug                 String
  name                 String
  address              String
  latitude             Float
  longitude            Float
  stopOrder            Int
  plannedDepartureTime DateTime?           @db.Timestamptz
  stopStatuses         ShuttleStopStatus[]

  @@unique([routeId, slug])
  @@unique([routeId, stopOrder])
}

model Driver {
  id          String             @id @default(cuid())
  name        String
  phone       String?
  pinHash     String
  createdAt   DateTime           @default(now()) @db.Timestamptz
  magicTokens DriverMagicToken[]
  sessions    ShuttleSession[]
}

model DriverMagicToken {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
}

model ShuttleSession {
  id           String               @id @default(cuid())
  routeId      String
  route        ShuttleRoute         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  driverId     String
  driver       Driver               @relation(fields: [driverId], references: [id], onDelete: Cascade)
  status       ShuttleSessionStatus @default(ACTIVE)
  startedAt    DateTime             @default(now()) @db.Timestamptz
  endedAt      DateTime?            @db.Timestamptz
  locations    ShuttleLocation[]
  stopStatuses ShuttleStopStatus[]
}

model ShuttleLocation {
  id         String         @id @default(cuid())
  sessionId  String
  session    ShuttleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  speed      Float?
  heading    Float?
  accuracy   Float?
  recordedAt DateTime       @default(now()) @db.Timestamptz

  @@index([sessionId, recordedAt(sort: Desc)])
}

model ShuttleStopStatus {
  id         String                @id @default(cuid())
  sessionId  String
  session    ShuttleSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stopId     String
  stop       ShuttleStop           @relation(fields: [stopId], references: [id], onDelete: Cascade)
  status     ShuttleStopStatusType @default(PENDING)
  arrivedAt  DateTime?             @db.Timestamptz
  departedAt DateTime?             @db.Timestamptz

  @@unique([sessionId, stopId])
}
