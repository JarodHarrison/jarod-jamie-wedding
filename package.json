{
  "name": "jarod-jamie-wedding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prisma-generate.mjs && next dev --hostname 0.0.0.0 -p 3001",
    "build": "node scripts/prisma-generate.mjs && next build",
    "vercel-build": "node scripts/prisma-generate.mjs && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "postinstall": "node scripts/prisma-generate.mjs",
    "lint": "eslint",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-eateries": "node -r dotenv/config ./node_modules/tsx/dist/cli.mjs scripts/sync-hinterland-eateries.ts",
    "db:sync-attractions": "node -r dotenv/config ./node_modules/tsx/dist/cli.mjs scripts/sync-hinterland-attractions.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@googlemaps/three": "^4.0.13",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "ai": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
