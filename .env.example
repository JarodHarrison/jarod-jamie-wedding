# ── Local development (Docker Postgres on port 5433) ──
DATABASE_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"
DIRECT_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"

# ── Production (Neon on Vercel) — use BOTH strings from neon.tech console ──
# DATABASE_URL = "Pooled connection" (host contains -pooler)
# DIRECT_URL   = "Direct connection" (host does NOT contain -pooler)

# Next.js app URL (local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Google sign-in (Google Cloud Console → OAuth 2.0 Client)
# Add a redirect URI for every host guests use, e.g.:
#   https://jarodandjamiewedding.com/api/auth/google/callback
#   https://your-project.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Passkeys (WebAuthn) — optional override; defaults to hostname from NEXT_PUBLIC_APP_URL
# WEBAUTHN_RP_ID="jarod-jamie-wedding-delta.vercel.app"

# AI wedding assistant — Annita Help (Google Gemini + optional Google Search grounding)
GOOGLE_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash-lite"
# Google Search grounding runs automatically for local food/attraction questions (uses same API key)

# Annita voice output (optional — for a consistent character voice)
# Best distinct voice: ElevenLabs — pick/create a voice at elevenlabs.io, copy Voice ID
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""
# ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"
# Fallback server voice: enable Cloud Text-to-Speech API on the same Google Cloud project
# GOOGLE_TTS_VOICE="en-AU-Neural2-C"

# Optional — seed password for demo guest (local only)
# SEED_GUEST_PASSWORD="GuestDemo2026!"

# Optional — Instagram hashtag photo wall
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_USER_ID=""
# INSTAGRAM_HASHTAG="J-rodandJamo"

# Email (Google Workspace SMTP)
# Create an App Password on your primary mailbox (e.g. notifications@...)
# NOTIFY_EMAIL = where guest registration/update alerts are delivered (to you)
NOTIFY_EMAIL="theboys@jarodandjamiewedding.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="notifications@jarodandjamiewedding.com"
SMTP_PASS=""
# From addresses — each mailbox must be set up as "Send mail as" on SMTP_USER
EMAIL_FROM_NOTIFICATIONS="Jarod & Jamie Wedding <notifications@jarodandjamiewedding.com>"
EMAIL_FROM_UPDATES="Jarod & Jamie Wedding <updates@jarodandjamiewedding.com>"
EMAIL_FROM_NOREPLY="Jarod & Jamie Wedding <noreply@jarodandjamiewedding.com>"

# Live shuttle tracking
# SHUTTLE_DRIVER_PIN="260926"
# SHUTTLE_FORCE_VISIBLE="true"
# Browser key — enable Maps JavaScript API + billing; restrict by HTTP referrer
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Vector Map ID (Cloud Console → Map Management) — required for 3D GLB models on the map
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""
# Drop custom models at public/shuttle/models/bus.glb and stop.glb (GLB format)
# GOOGLE_API_KEY also powers Directions/ETA on the server (enable Directions API)
