# ── Local development (Docker Postgres on port 5433) ──
DATABASE_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"
DIRECT_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"

# ── Production (Neon on Vercel) — use BOTH strings from neon.tech console ──
# DATABASE_URL = "Pooled connection" (host contains -pooler)
# DIRECT_URL   = "Direct connection" (host does NOT contain -pooler)

# Next.js app URL (local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Google sign-in (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# If sign-in fails with "isn't configured correctly", reset the client secret in Console
# and update GOOGLE_CLIENT_SECRET here + Vercel production env vars.
#
# OAuth consent screen: External | Authorized domains: jarodandjamiewedding.com
#
# Authorized JavaScript origins (no paths):
#   http://localhost:3001
#   https://jarodandjamiewedding.com
#
# Authorized redirect URIs (full callback path):
#   http://localhost:3001/api/auth/google/callback
#   https://jarodandjamiewedding.com/api/auth/google/callback
#   http://localhost:3001/api/admin/gmail/callback
#   https://jarodandjamiewedding.com/api/admin/gmail/callback
#   http://localhost:3001/api/admin/drive/callback
#   https://jarodandjamiewedding.com/api/admin/drive/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Passkeys (WebAuthn) — optional override; defaults to hostname from NEXT_PUBLIC_APP_URL
# WEBAUTHN_RP_ID="jarod-jamie-wedding-delta.vercel.app"

# AI wedding assistant — Annita Help (Google Gemini + optional Google Search grounding)
# Also powers Cloud Vision safe-search on guest photo uploads (enable Vision API in Google Cloud)
GOOGLE_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash-lite"

# Annita AI Gateway fallbacks (free-tier models only — used when direct Gemini fails)
# Auth: AI_GATEWAY_API_KEY or VERCEL_OIDC_TOKEN (auto on Vercel after enabling AI Gateway)
# AI_GATEWAY_API_KEY=""
# ANNITA_GATEWAY_FALLBACK_MODELS="google/gemini-2.5-flash,anthropic/claude-haiku-4.5"
# Google Search grounding runs automatically for local food/attraction questions (uses same API key)

# Annita voice output (optional — for a consistent character voice)
# Best distinct voice: ElevenLabs — pick/create a voice at elevenlabs.io, copy Voice ID
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""
# ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"
# ANNITA_SPEECH_RATE="1.15" # 0.85–1.35 — faster Annita voice (ElevenLabs + Google TTS)
# Fallback server voice: enable Cloud Text-to-Speech API on the same Google Cloud project
# GOOGLE_TTS_VOICE="en-AU-Neural2-C"

# Optional — seed password for demo guest (local only)
# SEED_GUEST_PASSWORD="GuestDemo2026!"

# Optional — Instagram hashtag photo wall
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_USER_ID=""
# INSTAGRAM_HASHTAG="J-rodandJamo"

# Email (Google Workspace — Gmail API + OAuth 2.0, recommended)
# 1. Enable Gmail API in Google Cloud Console (same project as GOOGLE_CLIENT_ID)
# 2. OAuth consent screen → add scope gmail.send; add test user OR set Internal (Workspace)
# 3. Add redirect URI: {APP_URL}/api/admin/gmail/callback (see list above)
# 4. Admin → Connect Gmail → sign in as theboys@ → copy refresh token to Vercel
NOTIFY_EMAIL="J-rodandJamie@outlook.com"
GMAIL_REFRESH_TOKEN=""
GMAIL_SENDER_EMAIL="theboys@jarodandjamiewedding.com"
EMAIL_FROM_NOTIFICATIONS="J-rod & Jamo <notifications@jarodandjamiewedding.com>"
EMAIL_FROM_UPDATES="J-rod & Jamo <updates@jarodandjamiewedding.com>"
EMAIL_FROM_NOREPLY="J-rod & Jamo <noreply@jarodandjamiewedding.com>"

# Legacy SMTP fallback (optional — app passwords not recommended by Google)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="notifications@jarodandjamiewedding.com"
# SMTP_PASS=""

# Live photo wall kiosk + guest uploads (optional Google Drive archive)
# GOOGLE_DRIVE_REFRESH_TOKEN=""   # from Admin → Connect Google Drive
# GOOGLE_DRIVE_FOLDER_ID=""       # Drive folder ID for guest uploads
# GUEST_PHOTO_VISION_MODERATION="false" # disable Google Vision safe-search (on when GOOGLE_API_KEY is set)
# Cloud Vision API must be enabled on the same Google Cloud project as GOOGLE_API_KEY
# Clean/borderline uploads auto-approve; only LIKELY/VERY_LIKELY unsafe content is blocked
# SHUTTLE_DRIVER_PIN="260926"
# SHUTTLE_FORCE_VISIBLE="true"
# NEXT_PUBLIC_VENUE_MAP_FORCE_VISIBLE="true" # show venue map to all guests (testing)
# Browser key — enable Maps JavaScript API + billing; restrict by HTTP referrer
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Vector Map ID (Cloud Console → Map Management) — required for 3D GLB models on the map
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""
# Drop custom models at public/shuttle/models/bus.glb and stop.glb (GLB format)
# GOOGLE_API_KEY also powers Directions/ETA on the server (enable Directions API)

