# ── Local development (Docker Postgres on port 5433) ──
DATABASE_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"
DIRECT_URL="postgresql://wedding:wedding@localhost:5433/wedding?schema=public"

# ── Production (Neon on Vercel) — use BOTH strings from neon.tech console ──
# DATABASE_URL = "Pooled connection" (host contains -pooler)
# DIRECT_URL   = "Direct connection" (host does NOT contain -pooler)

# Next.js app URL (local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# AI wedding assistant (Google Gemini — free tier at aistudio.google.com/apikey)
GOOGLE_API_KEY=""
# GEMINI_MODEL="gemini-flash-latest"

# Optional — seed password for demo guest (local only)
# SEED_GUEST_PASSWORD="GuestDemo2026!"

# Optional — Instagram hashtag photo wall
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_USER_ID=""
# INSTAGRAM_HASHTAG="J-rodandJamo"

# Email notifications (Resend — resend.com)
# NOTIFY_EMAIL defaults to j-rodandjamie@outlook.com if unset
NOTIFY_EMAIL="j-rodandjamie@outlook.com"
RESEND_API_KEY=""
# EMAIL_FROM="Jarod & Jamie Wedding <notifications@yourdomain.com>"

# Live shuttle tracking
# SHUTTLE_DRIVER_PIN="260926"
# SHUTTLE_FORCE_VISIBLE="true"
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# GOOGLE_API_KEY also powers Directions/ETA on the server
